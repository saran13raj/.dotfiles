# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = true
        interval = 5

		color_good = "#40c862"       # Green for "up" status
		color_degraded = "#cc9356"   # Orange for degraded connections
		color_bad = "#cc4444"        # Red for "down" status
}

# order += "ipv6"
order += "wireless _first_"
order += "ethernet _first_"
# order += "battery all"
order += "disk /"
order += "load"
order += "memory"
order += "volume master"
order += "tztime local"

wireless _first_ {
        format_up = " (%quality at %essid)"
        format_down = "  down"
}

ethernet _first_ {
        format_up = "󰈀 (%speed)"
        format_down = "󰈀 down"
}

battery all {
        format = "%status %percentage %remaining"
}

disk "/" {
        format = "  %avail"
}

load {
        format = "  %1min"
}

memory {
        format = "  %used"
        threshold_degraded = "1G"
        format_degraded = "MEMORY < %available"
}

volume master {
    format = " %volume"
    format_muted = "♪: muted (%volume)"
    device = "default"       # Use "pulse" for PulseAudio, or leave as "default" for ALSA fallback
    mixer = "Master"         # For ALSA only
    mixer_idx = 0            # For ALSA only
}


tztime local {
        format = "%Y-%b-%d %H:%M:%S"
}
